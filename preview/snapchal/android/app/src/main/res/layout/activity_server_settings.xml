<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#fdf8f3">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ngrok 또는 서버 URL 입력"
        android:textSize="14sp"
        android:textColor="#9e9e9e"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etServerUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="https://xxxx.ngrok-free.app"
        android:inputType="textUri"
        android:padding="14dp"
        android:background="@drawable/input_background"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="• ngrok 사용: ngrok http 8000 실행 후 나오는 URL 입력\n• 같은 Wi-Fi: http://[서버 IP]:8000 입력\n예) http://192.168.1.100:8000"
        android:textSize="13sp"
        android:textColor="#9e9e9e"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="저장 및 연결"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="#ff7043"
        android:padding="16dp"
        android:textColor="#ffffff"/>

</LinearLayout>
